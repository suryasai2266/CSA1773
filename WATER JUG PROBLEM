from collections import deque
def water_jug(a,b,target):
    q=deque([(0,0)])
    seen=set()
    while q:
        x,y=q.popleft()
        if x==target or y==target: return (x,y)
        if (x,y) in seen: continue
        seen.add((x,y))
        q.extend([(a,y),(x,b),(0,y),(x,0),
                  (min(a,x+y),0),(0,min(b,x+y)),
                  (x-(b-y),b),(a,y-(a-x))])
print(water_jug(4,3,2))
